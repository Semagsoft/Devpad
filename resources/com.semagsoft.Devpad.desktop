[Desktop Entry]
Type=Application
Name=Devpad
GenericName=Code Editor
Comment=A C++/Qt6 code editor with QScintilla syntax highlighting and embedded terminal
Exec=Devpad %F
Icon=com.semagsoft.Devpad
Terminal=false
Categories=Development;IDE;TextEditor;
MimeType=text/plain;text/x-c;text/x-c++;text/x-python;text/x-java;text/x-javascript;text/html;text/css;text/xml;text/x-sql;text/x-markdown;
Keywords=editor;code;programming;text;
StartupNotify=true
StartupWMClass=devpad
Actions=new-window;

[Desktop Action new-window]
Name=New Window
Exec=Devpad
